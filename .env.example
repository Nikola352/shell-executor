# Copy this file to .env and fill in your values.
# Load with: source .env  (or use direnv / dotenv)
# Variables with defaults are optional. Uncomment only if you need to override.

# Executor type (default: docker)
# EXECUTOR_TYPE=aws   # options: docker | aws

# PostgreSQL (defaults work with docker-compose)
# POSTGRES_URL=jdbc:postgresql://localhost:5432/shell-executor
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# Docker executor
# DOCKER_HOST=unix:///var/run/docker.sock

# AWS executor — required when EXECUTOR_TYPE=aws, others are optional overrides
AWS_KEY_NAME=your-key-pair-name
AWS_PEM_PATH=/absolute/path/to/your-key.pem
AWS_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx
AWS_SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
# AWS_REGION=eu-central-1
# AWS_AMI_ID=ami-05852c5f195d545ea
# AWS_SSH_USER=ubuntu
# AWS_SSH_PORT=22
# AWS_INSTANCE_TIMEOUT_SECONDS=120
# AWS_SSH_TIMEOUT_SECONDS=120
# AWS_SSH_RETRY_INTERVAL_MS=5000
